<Window x:Class="CafeAdisyon.Views.OdemeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ödeme Yap" Height="500" Width="600"
        Background="{StaticResource PrimaryBrush}"
        WindowStartupLocation="CenterScreen"
        FontFamily="{StaticResource DefaultFont}"
        ResizeMode="NoResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource AccentBrush}" Padding="20,15">
            <TextBlock Text="ÖDEME EKRANI - Parçalı Ödeme Yapabilirsiniz"
                      FontSize="16"
                      FontWeight="Bold"
                      Foreground="White"/>
        </Border>

        <!-- Ödeme Listesi -->
        <ListBox Grid.Row="1" Name="OdemeListesi" Margin="20"
                Background="{StaticResource PrimaryBrush}"
                BorderThickness="0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="12,10" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <CheckBox Grid.Column="0" Name="OdemeCheckBox" VerticalAlignment="Center"
                                     Margin="0,0,15,0" Checked="CheckBox_Checked" Unchecked="CheckBox_Unchecked"/>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding UrunAdi}"
                                          FontSize="13"
                                          FontWeight="Bold"
                                          Foreground="{StaticResource TextBrush}"/>
                                <TextBlock Text="{Binding Adet, StringFormat='Adet: {0}'}"
                                          FontSize="11"
                                          Foreground="#666666" Margin="0,3,0,0"/>
                                <TextBlock Text="{Binding Toplam, StringFormat='₺{0:F2}'}"
                                          FontSize="12"
                                          FontWeight="Bold"
                                          Foreground="{StaticResource AccentBrush}"
                                          Margin="0,5,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Summary ve Butonlar -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource SecondaryBrush}"
                   BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                   Padding="20,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                              Text="TOPLAM ÖDEYECEĞİNİZ:"
                              FontSize="13"
                              FontWeight="Bold"
                              Foreground="{StaticResource TextBrush}"/>

                    <TextBlock Grid.Column="1"
                              Name="ToplamOdemeTutar"
                              Text="₺0.00"
                              FontSize="16"
                              FontWeight="Bold"
                              Foreground="{StaticResource AccentBrush}"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="20,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                       Content="ÖDEMEYI TAMAMLA"
                       Style="{StaticResource PrimaryButtonStyle}"
                       Margin="0,0,10,0"
                       Click="OdemeYap_Click"
                       FontSize="13"/>

                <Button Grid.Column="1"
                       Content="İPTAL"
                       Style="{StaticResource PrimaryButtonStyle}"
                       Margin="10,0,0,0"
                       Background="#999999"
                       Click="Iptal_Click"
                       FontSize="13"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
