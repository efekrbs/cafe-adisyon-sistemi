<Window x:Class="CafeAdisyon.Views.OdemeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ödeme Yap" Height="500" Width="600"
        Background="{StaticResource PrimaryBrush}"
        WindowStartupLocation="CenterScreen"
        FontFamily="{StaticResource DefaultFont}"
        ResizeMode="NoResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource AccentBrush}" Padding="20,15">
            <TextBlock Text="ÖDEME EKRANI - Parçalı Ödeme Yapabilirsiniz"
                      FontSize="16"
                      FontWeight="Bold"
                      Foreground="White"/>
        </Border>

        <!-- Ödeme Listesi -->
        <ListBox Grid.Row="1" Name="OdemeListesi" Margin="15"
                Background="{StaticResource PrimaryBrush}"
                BorderThickness="0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Name="OdemeItemBorder" Padding="15" Margin="0,10,0,10"
                           BorderThickness="3" CornerRadius="10" Width="500"
                           BorderBrush="Transparent" MouseUp="Border_MouseUp"
                           Background="Transparent" Cursor="Hand" HorizontalAlignment="Stretch">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="45"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Checkbox / Check Icon -->
                            <Border Grid.Column="0" Width="45" Height="45" CornerRadius="8"
                                   Background="{StaticResource SecondaryBrush}"
                                   BorderBrush="{StaticResource BorderBrush}"
                                   BorderThickness="2" VerticalAlignment="Center">
                                <Grid>
                                    <TextBlock Name="CheckIcon" Text="✓" FontSize="24"
                                              Foreground="White" TextAlignment="Center"
                                              VerticalAlignment="Center" FontWeight="Bold"
                                              Opacity="0"/>
                                    <CheckBox Name="OdemeCheckBox" IsHitTestVisible="False"
                                             VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Ürün Bilgileri -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="15,0,15,0">
                                <TextBlock Text="{Binding UrunAdi}"
                                          FontSize="14" FontWeight="Bold"
                                          Foreground="{StaticResource TextBrush}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock Text="Adet:" FontSize="11" Foreground="#888888" VerticalAlignment="Center"/>
                                    <!-- Adet Seçici -->
                                    <Button Name="AdetAzaltBtn" Content="−" Width="24" Height="24" FontSize="14"
                                           Style="{StaticResource PrimaryButtonStyle}"
                                           Background="{StaticResource SecondaryBrush}"
                                           Foreground="{StaticResource TextBrush}"
                                           Margin="6,0,0,0" Padding="0"
                                           Click="AdetAzalt_Click" Tag="{Binding}"/>
                                    <TextBlock Text="{Binding SecilenAdet}" FontSize="13" FontWeight="Bold"
                                              Foreground="{StaticResource TextBrush}"
                                              VerticalAlignment="Center" Margin="8,0" MinWidth="20"
                                              TextAlignment="Center"/>
                                    <Button Name="AdetArtirBtn" Content="+" Width="24" Height="24" FontSize="14"
                                           Style="{StaticResource PrimaryButtonStyle}"
                                           Background="{StaticResource SecondaryBrush}"
                                           Foreground="{StaticResource TextBrush}"
                                           Padding="0"
                                           Click="AdetArtir_Click" Tag="{Binding}"/>
                                    <TextBlock Text="{Binding MaxAdet, StringFormat='/ {0}'}"
                                              FontSize="11" Foreground="#888888"
                                              VerticalAlignment="Center" Margin="6,0,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Seçilen Toplam Tutar -->
                            <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right"
                                      Text="{Binding SecilenToplam, StringFormat='₺{0:F2}'}"
                                      FontSize="16" FontWeight="Bold"
                                      Foreground="{StaticResource AccentBrush}"
                                      TextAlignment="Right" Margin="0,0,10,0"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Summary ve Butonlar -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource SecondaryBrush}"
                   BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                   Padding="20,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                              Text="TOPLAM ÖDEYECEĞİNİZ:"
                              FontSize="13"
                              FontWeight="Bold"
                              Foreground="{StaticResource TextBrush}"/>

                    <TextBlock Grid.Column="1"
                              Name="ToplamOdemeTutar"
                              Text="₺0.00"
                              FontSize="16"
                              FontWeight="Bold"
                              Foreground="{StaticResource AccentBrush}"/>
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="20,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                       Content="💵 NAKİT"
                       Style="{StaticResource PrimaryButtonStyle}"
                       Margin="0,0,8,0"
                       Background="#4CAF50"
                       Click="NakitOde_Click"
                       FontSize="13"/>

                <Button Grid.Column="1"
                       Content="💳 KART"
                       Style="{StaticResource PrimaryButtonStyle}"
                       Margin="8,0"
                       Background="#2196F3"
                       Click="KartOde_Click"
                       FontSize="13"/>

                <Button Grid.Column="2"
                       Content="İPTAL"
                       Style="{StaticResource PrimaryButtonStyle}"
                       Margin="8,0,0,0"
                       Background="#999999"
                       Click="Iptal_Click"
                       FontSize="13"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
