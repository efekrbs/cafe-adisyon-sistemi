<Window x:Class="CafeAdisyon.Views.AdisyonWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Adisyon Ekranı" Height="700" Width="1000"
        Background="{StaticResource PrimaryBrush}"
        WindowStartupLocation="CenterScreen"
        FontFamily="{StaticResource DefaultFont}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <!-- Menü Kısmı -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource SecondaryBrush}"
                   BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <TextBlock Text="MENÜ"
                          FontSize="20"
                          FontWeight="Bold"
                          Foreground="{StaticResource TextBrush}"
                          Padding="20,15"/>
            </Border>

            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Menu}" Margin="15">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Width="120" Height="100"
                                   Margin="8"
                                   Style="{StaticResource TableCardButtonStyle}"
                                   Command="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.UrunEkleCommand}"
                                   CommandParameter="{Binding}">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding UrunAdi}"
                                              FontSize="12"
                                              FontWeight="Bold"
                                              Foreground="{StaticResource TextBrush}"
                                              TextAlignment="Center"
                                              TextWrapping="Wrap"
                                              Margin="0,0,0,6"/>

                                    <TextBlock Text="{Binding Fiyat, StringFormat='₺{0:F2}'}"
                                              FontSize="14"
                                              Foreground="{StaticResource AccentBrush}"
                                              TextAlignment="Center"
                                              FontWeight="Bold"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Adisyon Özeti Kısmı -->
        <Grid Grid.Column="1" Background="{StaticResource SecondaryBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{StaticResource AccentBrush}">
                <StackPanel>
                    <TextBlock Text="{Binding SecilenMasa.MasaAdi}"
                              FontSize="18"
                              FontWeight="Bold"
                              Foreground="White"
                              Padding="15,10,15,5"/>
                    <TextBlock Text="ADİSYON DETAYLARI"
                              FontSize="12"
                              Foreground="White"
                              Opacity="0.9"
                              Padding="15,0,15,10"/>
                </StackPanel>
            </Border>

            <!-- Adisyon Listesi -->
            <ScrollViewer Grid.Row="1" Margin="0">
                <ItemsControl ItemsSource="{Binding MasaAdisyonlari}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{StaticResource BorderBrush}"
                                   BorderThickness="0,0,0,1"
                                   Padding="12,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding UrunAdi}"
                                                  FontSize="13"
                                                  FontWeight="Bold"
                                                  Foreground="{StaticResource TextBrush}"/>
                                        <TextBlock Text="{Binding Adet, StringFormat='Adet: {0}'}"
                                                  FontSize="11"
                                                  Foreground="#666666"/>
                                        <TextBlock Text="{Binding Toplam, StringFormat='₺{0:F2}'}"
                                                  FontSize="12"
                                                  FontWeight="Bold"
                                                  Foreground="{StaticResource AccentBrush}"
                                                  Margin="0,5,0,0"/>
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                           Content="✕"
                                           Width="32" Height="32"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource PrimaryButtonStyle}"
                                           Background="{StaticResource DangerBrush}"
                                           Command="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.UrunCikarCommand}"
                                           CommandParameter="{Binding}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Total ve Butonlar -->
            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource AccentBrush}" Padding="15,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                  Text="TOPLAM:"
                                  FontSize="14"
                                  FontWeight="Bold"
                                  Foreground="White"/>

                        <TextBlock Grid.Column="1"
                                  Text="{Binding ToplamTutar, StringFormat='₺{0:F2}'}"
                                  FontSize="20"
                                  FontWeight="Bold"
                                  Foreground="White"/>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                           Content="ÖDEME YAP"
                           Style="{StaticResource PrimaryButtonStyle}"
                           Margin="0,0,6,0"
                           Command="{Binding OdeCommand}"
                           FontSize="13"/>

                    <Button Grid.Column="1"
                           Content="KAPAT"
                           Style="{StaticResource PrimaryButtonStyle}"
                           Margin="6,0,0,0"
                           Background="#999999"
                           Command="{Binding KapaCommand}"
                           FontSize="13"/>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
