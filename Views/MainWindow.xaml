<Window x:Class="CafeAdisyon.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kafe Adisyon Sistemi" Height="800" Width="1200"
        Background="{StaticResource PrimaryBrush}"
        WindowStartupLocation="CenterScreen"
        FontFamily="{StaticResource DefaultFont}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Üst Bar -->
        <Border Grid.Row="0" Background="{StaticResource SecondaryBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                          Text="KAFE ADİSYON SİSTEMİ"
                          FontSize="24"
                          FontWeight="Bold"
                          Foreground="{StaticResource TextBrush}"/>

                <Button Grid.Column="1"
                       Content="🔄 Yenile"
                       Style="{StaticResource PrimaryButtonStyle}"
                       Margin="0,0,10,0"
                       Command="{Binding YenilemeCommand}"/>

                <Button Grid.Column="2"
                       Content="⚙️ Ayarlar"
                       Style="{StaticResource PrimaryButtonStyle}"
                       Command="{Binding AyarlarAcCommand}"/>
            </Grid>
        </Border>

        <!-- Masa Grid'i -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Masalar}" Margin="20">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"
                                  HorizontalAlignment="Left"
                                  Margin="0"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Width="140" Height="140"
                               Margin="10"
                               Style="{StaticResource TableCardButtonStyle}"
                               Command="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.MasaTiklaCommand}"
                               CommandParameter="{Binding}">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding MasaAdi}"
                                          FontSize="18"
                                          FontWeight="Bold"
                                          Foreground="{StaticResource TextBrush}"
                                          TextAlignment="Center"
                                          Margin="0,0,0,8"/>

                                <TextBlock Text="{Binding ToplamTutar, StringFormat='₺{0:F2}'}"
                                          FontSize="14"
                                          Foreground="{StaticResource AccentBrush}"
                                          TextAlignment="Center"
                                          Margin="0,0,0,8"/>

                                <Border Background="{StaticResource AccentBrush}"
                                       CornerRadius="4"
                                       Padding="8,4">
                                    <TextBlock Text="{Binding Durum}"
                                              Foreground="White"
                                              FontSize="12"
                                              FontWeight="Bold"
                                              TextAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
